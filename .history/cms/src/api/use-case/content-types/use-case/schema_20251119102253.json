{
  "kind": "collectionType",
  "collectionName": "use_cases",
  "info": {
    "singularName": "use-case",
    "pluralName": "use-cases",
    "displayName": "Use Case",
    "description": "Main categories: People, Athletes, Pets"
  },
  "options": {
    "draftAndPublish": true,
    "comment": ""
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "hero_title": {
      "type": "string"
    },
    "hero_description": {
      "type": "text"
    },
    "icon": {
      "type": "enumeration",
      "enum": [
        "user",
        "lightning",
        "paw"
      ],
      "default": "user"
    },
    "features": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::feature.feature",
      "mappedBy": "category"
    },
    "sub_categories": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::sub-category.sub-category",
      "mappedBy": "parent_use_case"
    }
  }
}
