{
  "kind": "collectionType",
  "collectionName": "features",
  "info": {
    "singularName": "feature",
    "pluralName": "features",
    "displayName": "Feature",
    "description": "Feature cards shown throughout the site"
  },
  "options": {
    "draftAndPublish": true,
    "comment": ""
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "icon": {
      "type": "enumeration",
      "enum": [
        "lightning",
        "user",
        "notification",
        "grid",
        "heart",
        "shield",
        "chart",
        "people",
        "clock",
        "bulb",
        "warning",
        "chat",
        "check"
      ],
      "default": "lightning"
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::use-case.use-case",
      "inversedBy": "features"
    }
  }
}
